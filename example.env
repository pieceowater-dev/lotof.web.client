## Optional frontend API overrides (loaded at build/dev startup)
# Leave these unset to call the current host through /api-* proxy paths.
# Set them only when the frontend must talk to backend ports/hosts directly.

# Hub Gateway base URL override
VITE_API_HUB=http://localhost:8080

# Atrace Gateway base URL override
VITE_API_ATRACE=http://localhost:8081

# Contacts Gateway base URL override
VITE_API_CONTACTS=http://localhost:8083

# Capital Gateway base URL override
# VITE_API_CAPITAL=http://localhost:8082

# Note: after changing these, restart the dev server (they are read at startup).
